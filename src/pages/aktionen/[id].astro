---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

// 1. Astro sagen, welche URLs es generieren soll
export async function getStaticPaths() {
  const alleAktionen = await getCollection('aktionen');
  return alleAktionen.map(aktion => ({
    params: { id: aktion.id },
    props: { aktion },
  }));
}

const { aktion } = Astro.props;
const data = aktion.data;
// 🚀 Favicon aus Keystatic laden (Achtung: 2x ../ weil wir in einem Unterordner sind)
const globalFiles = import.meta.glob('../../content/settings/global.json', { eager: true });
const globalText = Object.values(globalFiles).length > 0 ? (Object.values(globalFiles)[0] as any) : {};
const faviconPath = globalText.favicon ? `${globalText.favicon}?v=titanium2` : '/favicon.png?v=titanium2';

// 2. Das Markdown (den langen Text) rendern
const { Content } = await render(aktion);

// 3. Helper für Datum
let datumText = '';
if (data.zeitplanung?.discriminant === 'einmalig' && data.zeitplanung.value.datum) {
  const d = new Date(data.zeitplanung.value.datum);
  if (!isNaN(d.getTime())) {
    datumText = `${String(d.getDate()).padStart(2, '0')}.${String(d.getMonth() + 1).padStart(2, '0')}.${d.getFullYear()}`;
    if (data.zeitplanung.value.uhrzeit) datumText += ` um ${data.zeitplanung.value.uhrzeit} Uhr`;
  }
} else if (data.zeitplanung?.discriminant === 'wiederkehrend') {
  datumText = `🔄 ${data.zeitplanung.value.rhythmus}`;
  if (data.zeitplanung.value.uhrzeit) datumText += ` (${data.zeitplanung.value.uhrzeit} Uhr)`;
}

// 4. Helper für Custom Badges
// 🚀 Das mitdenkende Titanium-Badge (Jetzt mit PIRE-Grün für "Aktiv")
// 🚀 Das fehlerfreie Titanium-Badge
const renderBadge = (item: any) => {
  const badgeObj = item?.data?.status_badge || item?.status_badge; 
  
  if (badgeObj?.discriminant === 'none') return ''; 

  if (badgeObj?.discriminant === 'custom') {
    const c = badgeObj.value.farbe;
    const text = badgeObj.value.text || 'Info';
    if (c === 'green') return `<span class="bg-[#329A44]/15 text-[#287a36] border-[#329A44]/30 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full border shrink-0">${text}</span>`;
    if (c === 'yellow') return `<span class="bg-[#F8D800]/20 text-[#b39b00] border-[#F8D800]/40 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full border shrink-0">${text}</span>`;
    if (c === 'red') return `<span class="bg-[#E30A17]/10 text-[#E30A17] border-[#E30A17]/20 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full border shrink-0">${text}</span>`;
    return `<span class="bg-slate-100 text-slate-700 border-slate-200 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full border shrink-0">${text}</span>`;
  }
  
  const heute = new Date();
  heute.setHours(0, 0, 0, 0);
  let istVergangen = false;

  const zeitplanung = item?.data?.zeitplanung || item?.zeitplanung;
  if (zeitplanung?.discriminant === 'einmalig' && zeitplanung.value.datum) {
    const eventDate = new Date(zeitplanung.value.datum);
    if (eventDate < heute) istVergangen = true;
  }

  const anzeigeOrt = item?.data?.anzeige_ort || item?.anzeige_ort || [];

  if (anzeigeOrt.includes('archiv') || istVergangen) {
    // 🚀 TS-FIX: Hartes Wort statt undefinierter Variable!
    return `<span class="bg-slate-100 text-slate-600 border-slate-300 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full border shrink-0">Abgeschlossen</span>`;
  }
  
  return `<span class="bg-[#329A44]/15 text-[#287a36] border-[#329A44]/30 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full border shrink-0">Aktiv</span>`;
};
---

<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{data.titel} | PIRE Krefeld</title>
    <link rel="icon" href={faviconPath} />
    <link rel="shortcut icon" href={faviconPath} />
    <link rel="apple-touch-icon" href={faviconPath} />
    <style>
      /* Styling für das gerenderte Markdown */
      .prose h1 { font-size: 2.5rem; font-weight: 800; color: #0f172a; margin-bottom: 1.5rem; line-height: 1.2; }
      .prose h2 { font-size: 1.8rem; font-weight: 700; color: #1e293b; margin-top: 2.5rem; margin-bottom: 1rem; }
      .prose h3 { font-size: 1.4rem; font-weight: 700; color: #334155; margin-top: 2rem; margin-bottom: 0.75rem; }
      .prose p { margin-bottom: 1.5rem; line-height: 1.8; color: #475569; font-size: 1.125rem; }
      .prose a { color: #329A44; text-decoration: underline; font-weight: 600; }
      .prose ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1.5rem; color: #475569; }
      .prose li { margin-bottom: 0.5rem; }
      .prose img { border-radius: 1rem; margin: 2rem 0; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); width: 100%; height: auto; }
      .prose strong { color: #0f172a; font-weight: 700; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans antialiased selection:bg-[#329A44] selection:text-white pb-24">
    
    <header class="bg-white/95 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="javascript:history.back()" class="text-sm font-bold text-slate-500 hover:text-[#329A44] transition-colors">&larr; Zurück</a>
        <a href="/" class="font-bold text-slate-900 hover:text-[#329A44] transition-colors">PIRE Krefeld</a>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 pt-12">
      
      {/* 🖼️ BEITRAGSBILD HERO */}
      {data.details?.beitragsbild && (
        <div class="mb-10 rounded-3xl overflow-hidden shadow-xl border border-slate-200 bg-white">
          <img src={data.details.beitragsbild} alt={data.titel} class="w-full h-[300px] md:h-[450px] object-cover" />
        </div>
      )}

      {/* 🏷️ KOPFBEREICH */}
      <div class="mb-12 border-b border-slate-200 pb-10">
        <div class="flex flex-wrap items-center gap-4 mb-6">
          <div set:html={renderBadge(aktion)}></div>
          {datumText && <span class="text-sm font-bold text-slate-500 uppercase tracking-widest bg-slate-100 px-3 py-1 rounded-lg">{datumText}</span>}
          {data.details?.ort && <span class="text-sm font-bold text-slate-500 bg-slate-100 px-3 py-1 rounded-lg">📍 {data.details.ort}</span>}
        </div>
        
        <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 tracking-tight mb-6 leading-tight">{data.titel}</h1>
        
        {data.details?.kurzbeschreibung && (
          <p class="text-xl text-slate-600 font-medium leading-relaxed max-w-3xl">{data.details.kurzbeschreibung}</p>
        )}
      </div>

      <div class="grid lg:grid-cols-3 gap-12">
        {/* 📝 DER HAUPTARTIKEL (LINKS) */}
        <div class="lg:col-span-2 prose max-w-none">
          <Content />
        </div>

        {/* 💡 SIDEBAR (RECHTS): Fakten & Links */}
        <div class="lg:col-span-1 space-y-8">
          
          {/* FAKTEN-BOXEN */}
          {data.fakten && data.fakten.length > 0 && (
            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
              <h3 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-3">Auf einen Blick</h3>
              <ul class="space-y-4">
                {data.fakten.map((fakt: any) => (
                  <li class="flex items-start gap-3">
                    <span class="text-xl">{fakt.icon}</span>
                    <div>
                      <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider">{fakt.bezeichnung}</span>
                      <span class="text-slate-800 font-medium">{fakt.wert}</span>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {/* EXTERNE LINKS & BUTTONS (Z.B. WhatsApp) */}
          {data.aktionen_links && data.aktionen_links.length > 0 && (
            <div class="space-y-3">
              {data.aktionen_links.map((link: any) => (
                <a href={link.url} target="_blank" class="flex justify-center items-center w-full bg-[#329A44] hover:bg-[#287a36] text-white font-bold py-4 px-6 rounded-xl transition-transform hover:-translate-y-1 shadow-md gap-2">
                  <span>🔗</span> {link.label}
                </a>
              ))}
            </div>
          )}

        </div>
      </div>

      {/* 📚 DIE HISTORIE (Z.B. FÜR NEWROZ) */}
      {data.historie_aktiv?.discriminant === 'true' && data.historie_aktiv.value.length > 0 && (
        <div class="mt-20 pt-16 border-t border-slate-200">
          <div class="flex items-center gap-4 mb-10">
            <h2 class="text-3xl font-bold text-slate-900">📚 Historie & Rückblicke</h2>
            <div class="h-[2px] flex-grow bg-slate-200"></div>
          </div>
          
          <div class="space-y-8 pl-4 border-l-4 border-slate-200 ml-4">
            {data.historie_aktiv.value.map((eintrag: any) => (
              <div class="relative pl-8">
                {/* Der Zeitstrahl-Punkt */}
                <div class="absolute w-4 h-4 bg-[#329A44] rounded-full -left-[10px] top-1.5 ring-4 ring-white"></div>
                <h3 class="text-2xl font-bold text-slate-900 mb-2">{eintrag.jahr}</h3>
                <p class="text-slate-600 leading-relaxed text-lg">{eintrag.text}</p>
              </div>
            ))}
          </div>
        </div>
      )}

    </main>
  </body>
</html>