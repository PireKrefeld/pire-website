---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const projekte = await getCollection('projekte');
  return projekte.map(projekt => ({
    params: { id: projekt.id },
    props: { projekt },
  }));
}

const { projekt } = Astro.props;
const { Content } = await render(projekt);

const formatText = (text: string | undefined | null) => {
  if (!text) return '';
  return text.replace(/\n/g, '<br>');
};

const getBadgeStyle = (statusObj: any) => {
  if (!statusObj) return { text: 'Aktiv', css: 'bg-blue-100 text-blue-800 border-blue-200' };
  const type = statusObj.discriminant;
  
  if (type === 'custom') {
    const c = statusObj.value.farbe;
    const text = statusObj.value.text || 'Custom';
    if (c === 'green') return { text, css: 'bg-[#329A44]/15 text-[#287a36] border-[#329A44]/30' }; 
    if (c === 'yellow') return { text, css: 'bg-[#F8D800]/20 text-[#b39b00] border-[#F8D800]/40' };
    if (c === 'red') return { text, css: 'bg-[#E30A17]/10 text-[#E30A17] border-[#E30A17]/20' };   
    return { text, css: 'bg-slate-100 text-slate-700 border-slate-200' };
  }
  
  if (type === 'dauerhaft') return { text: 'Dauerhaftes Angebot', css: 'bg-[#329A44]/15 text-[#287a36] border-[#329A44]/30' };
  if (type === 'aktiv') return { text: 'Aktives Projekt', css: 'bg-blue-100 text-blue-800 border-blue-200' };
  if (type === 'abgeschlossen') return { text: 'Abgeschlossen', css: 'bg-slate-100 text-slate-600 border-slate-300' };
  if (type === 'abgebrochen') return { text: 'Abgebrochen', css: 'bg-[#E30A17]/10 text-[#E30A17] border-[#E30A17]/20' };
  
  return { text: type, css: 'bg-slate-100 text-slate-700 border-slate-200' };
};

const badge = getBadgeStyle(projekt.data.status);
---

<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{projekt.data.titel} | PIRE Krefeld</title>
    <style is:global>
      .prose a { color: #329A44; text-decoration: underline; }
      .prose p { margin-bottom: 1.5rem; line-height: 1.8; color: #475569; }
      .prose h2 { font-size: 1.875rem; font-weight: 800; margin-top: 3rem; margin-bottom: 1rem; color: #0f172a; }
      .prose h3 { font-size: 1.5rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; color: #1e293b; }
      .prose ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1.5rem; color: #475569; }
      .prose ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 1.5rem; color: #475569; }
      .prose li { margin-bottom: 0.5rem; }
      .prose blockquote { border-left: 4px solid #329A44; padding-left: 1rem; font-style: italic; background: #f8fafc; padding: 1rem; border-radius: 0 0.5rem 0.5rem 0; margin-bottom: 1.5rem;}
      .prose img { border-radius: 1rem; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); margin: 2rem 0; width: 100%; height: auto; }
      
      .prose hr:first-child { display: none; }
      .prose hr { border: 0; border-top: 2px solid #e2e8f0; margin: 3rem 0; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans antialiased selection:bg-[#329A44] selection:text-white pb-20">
    
    <header class="bg-white/95 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-sm font-bold text-slate-500 hover:text-[#329A44] transition-colors">&larr; Zurück</a>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-16">
      <div class="mb-12">
        <div class="flex flex-wrap gap-4 items-center mb-6">
          <span class={`${badge.css} text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full border`}>
            {badge.text}
          </span>
        </div>
        
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight leading-tight mb-6">
          {projekt.data.titel}
        </h1>
        
        <p class="text-xl text-slate-500 font-medium leading-relaxed pb-8 border-b border-slate-200" set:html={formatText(projekt.data.kurzbeschreibung)}></p>
      </div>

      {projekt.data.fakten && projekt.data.fakten.length > 0 && (
        <div class="bg-slate-100 p-6 rounded-2xl mb-12 border border-slate-200">
          <h3 class="font-bold text-slate-900 mb-4 uppercase tracking-wider text-sm">Auf einen Blick</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            {projekt.data.fakten.map((fakt: any) => (
              <div class="flex items-start gap-3 bg-white p-3 rounded-xl border border-slate-100 shadow-sm">
                <span class="text-xl shrink-0">{fakt.icon}</span>
                <div>
                  <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">{fakt.bezeichnung}</span>
                  <span class="block text-slate-700 font-medium">{fakt.wert}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <article class="prose max-w-none">
        <Content />
      </article>

    </main>
  </body>
</html>