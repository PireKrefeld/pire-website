---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const alleProjekte = await getCollection('projekte');
---

<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aktions-Archiv | PIRE Krefeld</title>
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans antialiased">
    
    <header class="bg-white border-b border-slate-200 py-4 px-6 sticky top-0 z-50 shadow-sm">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="font-bold text-slate-900 hover:text-[#329A44] transition-colors">&larr; Startseite</a>
        <span class="text-sm font-black uppercase tracking-widest text-slate-400">Archiv</span>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-16">
      <h1 class="text-4xl md:text-6xl font-black text-slate-900 mb-6">Alle Projekte & Aktionen</h1>
      <p class="text-lg text-slate-600 mb-16 border-b border-slate-200 pb-8">Transparenz ist unsere Stärke. Hier findest du alle laufenden, abgeschlossenen und fehlgeschlagenen Aktionen.</p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {alleProjekte.map((projekt) => (
          <a href={`/projekte/${projekt.id}`} class="bg-white border border-slate-200 p-8 rounded-2xl hover:border-slate-400 hover:shadow-lg transition-all block group">
            <span class="text-slate-500 text-[10px] font-bold uppercase tracking-widest bg-slate-100 px-3 py-1 rounded-full mb-4 inline-block">
              {projekt.data.status}
            </span>
            <h2 class="text-2xl font-bold text-slate-900 mb-3 group-hover:text-[#329A44] transition-colors">{projekt.data.titel}</h2>
            <p class="text-slate-600 text-sm line-clamp-3">{projekt.data.kurzbeschreibung}</p>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>