---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const alleProjekte = await getCollection('projekte');

// 🚀 Der gleiche smarte Helper wie auf der Startseite
const getBadgeStyle = (statusObj: any) => {
  if (!statusObj) return { text: 'Aktiv', css: 'bg-blue-100 text-blue-800 border-blue-200' };
  const type = statusObj.discriminant;
  
  if (type === 'custom') {
    const c = statusObj.value.farbe;
    const text = statusObj.value.text || 'Custom';
    if (c === 'green') return { text, css: 'bg-[#329A44]/15 text-[#287a36] border-[#329A44]/30' }; 
    if (c === 'yellow') return { text, css: 'bg-[#F8D800]/20 text-[#b39b00] border-[#F8D800]/40' };
    if (c === 'red') return { text, css: 'bg-[#E30A17]/10 text-[#E30A17] border-[#E30A17]/20' };   
    return { text, css: 'bg-slate-100 text-slate-700 border-slate-200' };
  }
  
  if (type === 'dauerhaft') return { text: 'Dauerhaftes Angebot', css: 'bg-[#329A44]/15 text-[#287a36] border-[#329A44]/30' };
  if (type === 'aktiv') return { text: 'Aktives Projekt', css: 'bg-blue-100 text-blue-800 border-blue-200' };
  if (type === 'abgeschlossen') return { text: 'Abgeschlossen', css: 'bg-slate-100 text-slate-600 border-slate-300' };
  if (type === 'abgebrochen') return { text: 'Abgebrochen', css: 'bg-[#E30A17]/10 text-[#E30A17] border-[#E30A17]/20' };
  
  return { text: type, css: 'bg-slate-100 text-slate-700 border-slate-200' };
};
---

<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Archiv | PIRE Krefeld</title>
    <style>
      .rich-text a { color: #329A44; text-decoration: underline; }
      .rich-text b, .rich-text strong { font-weight: 800; color: #1e293b; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans antialiased selection:bg-[#329A44] selection:text-white">
    
    <header class="bg-white/95 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-sm font-bold text-slate-500 hover:text-[#329A44] transition-colors">&larr; Zurück zur Startseite</a>
        <span class="font-bold text-slate-900">Aktions-Archiv</span>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-16">
      <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-4">Projekt-Archiv</h1>
      <p class="text-lg text-slate-600 mb-12">Alle unsere bisherigen, aktuellen und dauerhaften Aktionen im Überblick.</p>

      <div class="grid gap-6">
        {alleProjekte.map(projekt => {
          const badge = getBadgeStyle(projekt.data.status);

          return (
            <a href={`/projekte/${projekt.id}`} class="bg-white border border-slate-200 p-6 md:p-8 rounded-2xl hover:border-[#329A44] hover:shadow-lg transition-all group block">
              <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-4">
                <h3 class="text-2xl font-bold text-slate-900 group-hover:text-[#329A44] transition-colors">{projekt.data.titel}</h3>
                
                {/* 🚀 FIXED: Kein [object Object] mehr, sondern das farbige Badge */}
                <span class={`${badge.css} text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full border inline-block shrink-0`}>
                  {badge.text}
                </span>
              </div>
              
              <p class="rich-text text-slate-600 mb-6" set:html={projekt.data.kurzbeschreibung}></p>
              
              <span class="text-sm font-bold text-[#329A44]">Kompletten Artikel lesen &rarr;</span>
            </a>
          );
        })}
      </div>
    </main>
  </body>
</html>