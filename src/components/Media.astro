---
const { url } = Astro.props;

let iframeSrc = url;
let isInsta = url.includes("instagram.com");
let isYoutube = url.includes("youtube.com") || url.includes("youtu.be");

// YouTube-Link in einen Embed-Link umwandeln
if (isYoutube) {
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regExp);
  const videoId = (match && match[2].length === 11) ? match[2] : null;
  if (videoId) iframeSrc = `https://www.youtube.com/embed/${videoId}`;
} 
// Instagram-Link in einen Embed-Link umwandeln
else if (isInsta) {
  iframeSrc = url.split("?")[0].replace(/\/$/, "") + "/embed";
}
---

<div class="my-8 flex justify-center w-full">
  {isYoutube ? (
    <iframe 
      src={iframeSrc} 
      class="w-full aspect-video rounded-xl shadow-md border border-slate-200" 
      frameborder="0" 
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
      allowfullscreen
    ></iframe>
  ) : isInsta ? (
    <iframe 
      src={iframeSrc} 
      width="100%" height="480" frameborder="0" scrolling="no" allowtransparency="true"
      class="rounded-xl border border-slate-200 shadow-sm max-w-md w-full"
    ></iframe>
  ) : (
    <div class="p-4 bg-red-50 text-red-600 border border-red-200 rounded-lg text-sm">
      Link wird (noch) nicht unterstützt. Bitte nutze YouTube oder Instagram.
    </div>
  )}
</div>